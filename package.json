{
  "name": "autoskill-md",
  "version": "0.1.1",
  "description": "Generate /.well-known/skills.md from code comments and route hints.",
  "type": "module",
  "license": "CC-BY-4.0",
  "author": "Colin Knapp and contributors",
  "homepage": "https://github.com/Leopere/autoskill-md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Leopere/autoskill-md.git"
  },
  "bin": {
    "autoskill-md": "./bin/autoskill-md.js"
  },
  "files": [
    ".well-known",
    "autoskill.config.json",
    "bin",
    "docs",
    "src",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "autoskill": "node ./bin/autoskill-md.js generate",
    "autoskill:check": "node ./bin/autoskill-md.js check --strict",
    "build": "node ./bin/autoskill-md.js generate --quiet",
    "check": "node ./bin/autoskill-md.js check --strict",
    "pack:check": "npm pack --dry-run",
    "test": "node --test",
    "verify": "npm run build && npm run check && npm test && npm run pack:check"
  },
  "engines": {
    "node": ">=20"
  }
}

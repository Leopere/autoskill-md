{
  "name": "autoskill-md",
  "version": "0.2.0",
  "description": "Native autoskill-md wrapper for generating /.well-known/skills.md.",
  "type": "module",
  "license": "CC-BY-4.0",
  "author": "Colin Knapp and contributors",
  "homepage": "https://github.com/Leopere/autoskill-md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Leopere/autoskill-md.git"
  },
  "bin": {
    "autoskill-md": "./bin/autoskill-md.js"
  },
  "files": [
    ".well-known",
    "autoskill.config.json",
    "bin",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node ./bin/install.js",
    "autoskill": "node ./bin/autoskill-md.js generate",
    "autoskill:check": "node ./bin/autoskill-md.js check --strict",
    "build": "cargo build --release && ./target/release/autoskill-md generate --quiet",
    "check": "./target/release/autoskill-md check --strict",
    "crate:check": "cargo package --allow-dirty --no-verify",
    "pack:check": "npm pack --dry-run",
    "test": "cargo test",
    "test:wrappers": "node ./bin/autoskill-md.js --version && python3 -m autoskill_md --version && go run ./cmd/autoskill-md --version",
    "verify": "npm run build && npm run check && npm test && npm run test:wrappers && npm run crate:check && npm run pack:check"
  },
  "engines": {
    "node": ">=20"
  }
}
